// ─────────────────────────────────────────────────────────────────────────────
// Nexus — Prisma Schema
// Database: PostgreSQL (Aurora compatible)
// ORM: Prisma v5
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma/client"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum RoomStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum MessageType {
  TEXT
  IMAGE
  VOICE_NOTE
  VIDEO
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

// ─────────────────────────────────────────────────────────────────────────────
// MIGRATION 0001 — IAM
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  handle       String    @unique
  name         String
  passwordHash String
  avatarUrl    String?
  bio          String?
  role         UserRole  @default(USER)
  permissions  String[]  @default([])
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  deviceSessions   DeviceSession[]
  roomModerations  RoomModerator[]
  dmConversations1 DMConversation[] @relation("Participant1")
  dmConversations2 DMConversation[] @relation("Participant2")

  // Phase 3 relations
  sentMessages    Message[]        @relation("SentMessages")
  messageStatuses MessageStatus_[] @relation("RecipientStatuses")
  reactions       Reaction[]
  blockedUsers    BlockedUser[]    @relation("Blocker")
  blockedByUsers  BlockedUser[]    @relation("Blocked")
  mutedItems      MutedConversation[]
  pinnedMessages  PinnedMessage[]

  @@index([email])
  @@index([handle])
  @@index([role])
  @@map("users")
}

model DeviceSession {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @db.Uuid
  deviceId         String
  platform         DevicePlatform
  pushToken        String?
  refreshTokenHash String
  deviceName       String?
  deviceModel      String?
  ipAddress        String?
  lastSeenAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("device_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MIGRATION 0002 — ROOMS
// ─────────────────────────────────────────────────────────────────────────────

model Room {
  id              String     @id @default(uuid()) @db.Uuid
  name            String     @unique
  slug            String     @unique
  description     String?
  avatarUrl       String?
  category        String
  tags            String[]   @default([])
  status          RoomStatus @default(ACTIVE)
  slowModeSeconds Int?
  createdBy       String     @db.Uuid
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  moderators RoomModerator[]
  messages   Message[]
  pins       PinnedMessage[]
  mutedBy    MutedConversation[]

  @@index([status])
  @@index([category])
  @@index([slug])
  @@map("rooms")
}

model RoomModerator {
  id         String   @id @default(uuid()) @db.Uuid
  roomId     String   @db.Uuid
  userId     String   @db.Uuid
  assignedBy String   @db.Uuid
  assignedAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@map("room_moderators")
}

// ─────────────────────────────────────────────────────────────────────────────
// MIGRATION 0003 — DM CONVERSATIONS
// ─────────────────────────────────────────────────────────────────────────────

model DMConversation {
  id             String   @id @default(uuid()) @db.Uuid
  participant1Id String   @db.Uuid
  participant2Id String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participant1 User      @relation("Participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User      @relation("Participant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     Message[]
  mutedBy      MutedConversation[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("dm_conversations")
}

// ─────────────────────────────────────────────────────────────────────────────
// MIGRATION 0004 — USER RELATIONSHIPS
// ─────────────────────────────────────────────────────────────────────────────

model BlockedUser {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@map("blocked_users")
}

model MutedConversation {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  roomId           String?   @db.Uuid
  dmConversationId String?   @db.Uuid
  mutedUntil       DateTime?
  createdAt        DateTime  @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  room           Room?           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  dmConversation DMConversation? @relation(fields: [dmConversationId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@unique([userId, dmConversationId])
  @@index([userId])
  @@map("muted_conversations")
}

// ─────────────────────────────────────────────────────────────────────────────
// MIGRATION 0005 — MESSAGES
// NOTE: In production, partition messages by room_id after migration.
// See prisma/init.sql for partition DDL instructions.
// ─────────────────────────────────────────────────────────────────────────────

model Message {
  id               String      @id @default(uuid()) @db.Uuid
  type             MessageType @default(TEXT)
  content          String?
  mediaUrl         String?
  mediaMetadata    Json?
  senderId         String      @db.Uuid
  roomId           String?     @db.Uuid
  dmConversationId String?     @db.Uuid
  replyToId        String?     @db.Uuid
  isEdited         Boolean     @default(false)
  editedAt         DateTime?
  deletedAt        DateTime?
  clientTempId     String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  sender         User             @relation("SentMessages", fields: [senderId], references: [id])
  room           Room?            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  dmConversation DMConversation?  @relation(fields: [dmConversationId], references: [id], onDelete: Cascade)
  replyTo        Message?         @relation("Replies", fields: [replyToId], references: [id])
  replies        Message[]        @relation("Replies")
  statuses       MessageStatus_[]
  reactions      Reaction[]
  pins           PinnedMessage[]

  @@index([roomId, createdAt(sort: Desc)])
  @@index([dmConversationId, createdAt(sort: Desc)])
  @@index([senderId, createdAt(sort: Desc)])
  @@index([clientTempId])
  @@map("messages")
}

model MessageStatus_ {
  id          String        @id @default(uuid()) @db.Uuid
  messageId   String        @db.Uuid
  recipientId String        @db.Uuid
  status      MessageStatus @default(SENT)
  updatedAt   DateTime      @updatedAt

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient User    @relation("RecipientStatuses", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([messageId, recipientId])
  @@index([messageId])
  @@index([recipientId])
  @@map("message_statuses")
}

model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

model PinnedMessage {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  messageId String   @db.Uuid
  pinnedBy  String   @db.Uuid
  pinnedAt  DateTime @default(now())

  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinner  User    @relation(fields: [pinnedBy], references: [id])

  @@unique([roomId, messageId])
  @@index([roomId])
  @@map("pinned_messages")
}
