# ─────────────────────────────────────────────────────────────────
# NEXUS — Environment Variables
# Copy this file to .env and fill in values before running the app
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_NAME=Nexus
APP_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Database ─────────────────────────────────────────────────────
# Local dev (Docker Compose)
DATABASE_URL=postgresql://nexus:nexus_secret@localhost:5432/nexus_db?schema=public

# Production (Aurora + PgBouncer)
# DATABASE_URL=postgresql://user:pass@pgbouncer-host:6432/nexus_db?schema=public&pgbouncer=true&connection_limit=1

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:6379  # Alternative single-string form

# ── JWT ──────────────────────────────────────────────────────────
# IMPORTANT: Use long random strings in production (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_min_64_chars_change_in_production
JWT_ACCESS_EXPIRY=15m

JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars_change_in_production
JWT_REFRESH_EXPIRY=30d

JWT_RESET_SECRET=your_reset_token_secret_min_64_chars_change_in_production
JWT_RESET_EXPIRY=1h

# ── Storage Provider ─────────────────────────────────────────────
# Options: firebase | r2
STORAGE_PROVIDER=firebase

# Firebase Storage
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Base64-encoded service account JSON
# Generate: cat service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Cloudflare R2 (alternative provider)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexus-media
R2_PUBLIC_URL=https://media.your-domain.com

# ── Email / SMTP ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Nexus
SMTP_FROM_EMAIL=noreply@your-domain.com

# ── Rate Limiting ────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── BullMQ ───────────────────────────────────────────────────────
# Uses REDIS_HOST / REDIS_PORT above
BULL_BOARD_ENABLED=true

# ── Swagger ──────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ── Media Limits ─────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100
MAX_VOICE_SIZE_MB=10

# ── Admin ────────────────────────────────────────────────────────
# Comma-separated IPs allowed to access admin endpoints in production
ADMIN_IP_ALLOWLIST=127.0.0.1
